   "source": "# ── UMAP image mosaic ─────────────────────────────────────────────────────────\n# Divide the UMAP embedding into an N×N grid. For each occupied bin, place the\n# cell whose UMAP coordinate is closest to the bin centre. Two panels: membrane\n# (ch 0) and nuclei (ch 1). Gives a spatial \"what does the latent space look\n# like\" summary using real cell images rather than coloured dots.\n#\n# Inspired by: github.com/jmhb0/o2vae examples/analysis_mefs.ipynb cell 19\n\nimport matplotlib.pyplot as plt\n\nGRID_N  = 20     # N×N bins over the UMAP extent\nCELL_PX = 64     # pixels per bin in the output mosaic\n\n# ── decode thumbnails → per-channel uint8 arrays ─────────────────────────────\ndef _decode_thumb(b64: str, size: int = THUMB_PX):\n    \"\"\"base64 PNG (membrane|nuclei side-by-side) → two (size,size) uint8 arrays.\"\"\"\n    raw = base64.b64decode(b64.split(\",\", 1)[1])\n    img = np.array(Image.open(io.BytesIO(raw)))   # (size, 2*size) grayscale\n    return img[:, :size], img[:, size:]\n\n# ── bin every cell into the grid ─────────────────────────────────────────────\nx_min, x_max = xy[:, 0].min(), xy[:, 0].max()\ny_min, y_max = xy[:, 1].min(), xy[:, 1].max()\nx_edges = np.linspace(x_min, x_max, GRID_N + 1)\ny_edges = np.linspace(y_min, y_max, GRID_N + 1)\n\nxi = np.clip(np.digitize(xy[:, 0], x_edges) - 1, 0, GRID_N - 1)\nyi = np.clip(np.digitize(xy[:, 1], y_edges) - 1, 0, GRID_N - 1)\n\n# per bin: keep only the cell closest to the bin centre\nbin_rep = {}   # (bx, by) -> cell index\nfor i in range(len(xy)):\n    bx, by = int(xi[i]), int(yi[i])\n    cx = (x_edges[bx] + x_edges[bx + 1]) / 2\n    cy = (y_edges[by] + y_edges[by + 1]) / 2\n    dist = (xy[i, 0] - cx) ** 2 + (xy[i, 1] - cy) ** 2\n    if (bx, by) not in bin_rep or dist < bin_rep[(bx, by)][0]:\n        bin_rep[(bx, by)] = (dist, i)\n\n# ── build mosaic images ───────────────────────────────────────────────────────\nmem_mosaic = np.zeros((GRID_N * CELL_PX, GRID_N * CELL_PX), dtype=np.uint8)\nnuc_mosaic = np.zeros((GRID_N * CELL_PX, GRID_N * CELL_PX), dtype=np.uint8)\n\nfor (bx, by), (_, idx) in bin_rep.items():\n    mem_ch, nuc_ch = _decode_thumb(all_thumbs[idx], size=THUMB_PX)\n    mem_r = np.array(Image.fromarray(mem_ch).resize((CELL_PX, CELL_PX), Image.LANCZOS))\n    nuc_r = np.array(Image.fromarray(nuc_ch).resize((CELL_PX, CELL_PX), Image.LANCZOS))\n    # flip y so UMAP \"up\" = image top row\n    row = (GRID_N - 1 - by) * CELL_PX\n    col = bx * CELL_PX\n    mem_mosaic[row:row + CELL_PX, col:col + CELL_PX] = mem_r\n    nuc_mosaic[row:row + CELL_PX, col:col + CELL_PX] = nuc_r\n\n# ── plot & save ───────────────────────────────────────────────────────────────\nfig, axes = plt.subplots(1, 2, figsize=(18, 9), facecolor=\"black\")\nfor ax, mosaic, title in zip(\n    axes,\n    [mem_mosaic, nuc_mosaic],\n    [\"Membrane  (UMAP grid)\", \"Nuclei  (UMAP grid)\"],\n):\n    ax.imshow(mosaic, cmap=\"gray\", aspect=\"equal\", interpolation=\"nearest\")\n    ax.set_title(title, color=\"white\", fontsize=14, pad=8)\n    ax.axis(\"off\")\n\nplt.tight_layout(pad=0.5)\nout_mosaic = OUT_DIR / \"umap_mosaic.png\"\nplt.savefig(out_mosaic, dpi=150, bbox_inches=\"tight\", facecolor=\"black\")\nplt.show()\nprint(f\"Saved : {out_mosaic}\")\nprint(f\"Grid  : {GRID_N}×{GRID_N}  |  {len(bin_rep)} / {GRID_N**2} bins occupied\")",
